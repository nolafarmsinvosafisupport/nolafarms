# Database (Railway Postgres — copy the connection string from the Postgres
# service's "Connect" tab in Railway; use the internal railway.internal URL
# for the app's own DATABASE_URL, it's faster and free of egress cost)
DATABASE_URL=

# Clerk (clerk.com — use pk_live_/sk_live_ from a Production instance once live)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/account/profile
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/account/profile
# The Clerk user ID (starts with "user_") of the account that should have
# admin access — must come from the same instance (test vs. production) as
# the keys above, since each instance has its own separate user list.
CLERK_ADMIN_USER_ID=

# Cloudflare R2 (dash.cloudflare.com -> R2 -> create a bucket, then
# "Manage API Tokens" -> create a token scoped to that bucket). Used for
# admin-uploaded product images. Leave all four blank and the admin product
# form falls back to manual /public path entry — nothing breaks either way.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# The base URL images are served from — either the bucket's R2 custom domain
# (recommended, e.g. https://images.nolafarms.co.ke) or, before that's set
# up, the bucket's public r2.dev URL from the R2 dashboard.
R2_PUBLIC_URL=

# Resend (resend.com) — booking/contact emails
RESEND_API_KEY=
RESEND_FROM_EMAIL=bookings@nolafarms.co.ke
ADMIN_NOTIFICATION_EMAIL=

# Daily booking-reminder cron (see .github/workflows/send-reminders.yml) —
# set the same value here and as a GitHub Actions repo secret.
CRON_SECRET=

# App
NEXT_PUBLIC_SITE_URL=https://nolafarms.co.ke
